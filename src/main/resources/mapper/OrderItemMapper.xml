<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qiukai.mapper.OrderItemMapper">

    <resultMap id="itemResultMap" type="com.qiukai.entity.OrderItem">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="dishId" column="dish_id"/>
        <result property="dishName" column="dish_name"/>
        <result property="dishImage" column="dish_image"/>
        <result property="unitPrice" column="unit_price"/>
        <result property="qty" column="qty"/>
        <result property="optionsText" column="options_text"/>
        <result property="subtotal" column="subtotal"/>
    </resultMap>

    <insert id="insertBatch">
        INSERT INTO order_item (order_id, dish_id, dish_name, dish_image, unit_price, qty, options_text, subtotal)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.orderId}, #{item.dishId}, #{item.dishName}, #{item.dishImage},
             #{item.unitPrice}, #{item.qty}, #{item.optionsText}, #{item.subtotal})
        </foreach>
    </insert>

    <select id="selectByOrderId" resultMap="itemResultMap">
        SELECT id, order_id, dish_id, dish_name, dish_image, unit_price, qty, options_text, subtotal
        FROM order_item WHERE order_id = #{orderId}
    </select>

</mapper>
