<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qiukai.mapper.UserMapper">

    <resultMap id="userResultMap" type="com.qiukai.entity.User">
        <id property="id" column="id"/>
        <result property="phone" column="phone"/>
        <result property="username" column="username"/>
        <result property="nickname" column="nickname"/>
        <result property="password" column="password"/>
        <result property="avatar" column="avatar"/>
        <result property="gender" column="gender"/>
        <result property="role" column="role"/>
        <result property="memberLevel" column="member_level"/>
        <result property="points" column="points"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="allColumns">
        id, phone, username, nickname, password, avatar, gender, role, member_level, points, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="userResultMap">
        SELECT <include refid="allColumns"/> FROM user WHERE id = #{id}
    </select>

    <select id="selectByPhone" resultMap="userResultMap">
        SELECT <include refid="allColumns"/> FROM user WHERE phone = #{phone}
    </select>

    <select id="selectByUsername" resultMap="userResultMap">
        SELECT <include refid="allColumns"/> FROM user WHERE username = #{username}
    </select>

    <insert id="insert" parameterType="com.qiukai.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (phone, username, nickname, password, avatar, gender, role, member_level, points, status)
        VALUES (#{phone}, #{username}, #{nickname}, #{password}, #{avatar}, #{gender}, #{role}, #{memberLevel}, #{points}, #{status})
    </insert>

    <update id="updateProfile" parameterType="com.qiukai.entity.User">
        UPDATE user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="memberLevel != null">member_level = #{memberLevel},</if>
            <if test="points != null">points = #{points},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateAvatar">
        UPDATE user SET avatar = #{avatar} WHERE id = #{id}
    </update>

    <update id="updatePassword">
        UPDATE user SET password = #{password} WHERE id = #{id}
    </update>

    <update id="addPoints">
        UPDATE user SET points = points + #{delta} WHERE id = #{id}
    </update>

</mapper>
