<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qiukai.mapper.PromoRuleMapper">

    <resultMap id="ruleResultMap" type="com.qiukai.entity.PromoRule">
        <id property="id" column="id"/>
        <result property="merchantId" column="merchant_id"/>
        <result property="threshold" column="threshold"/>
        <result property="discount" column="discount"/>
    </resultMap>

    <select id="selectByMerchantId" resultMap="ruleResultMap">
        SELECT id, merchant_id, threshold, discount
        FROM promo_rule WHERE merchant_id = #{merchantId} ORDER BY threshold ASC
    </select>

</mapper>
